{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @workspace/api-server --filter @workspace/glam-crm run dev",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:web": "pnpm --filter @workspace/glam-crm run dev",
    "db:push": "DATABASE_URL=${DATABASE_URL:-postgres://makeup_artist_hub:makeup_artist_hub@localhost:5432/makeup_artist_hub} pnpm --filter @workspace/db run push",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
